# Порт сервера
PORT=3001

# Порт фронтенда (Vite dev server)
FRONTEND_PORT=3002

# Режим работы (development|production|test)
NODE_ENV=development

# URL фронтенда для CORS
FRONTEND_URL=http://localhost:3002

# URL API для фронтенда (используется Vite)
VITE_API_URL=http://localhost:3001

# Длительность сессии в минутах
SESSION_DURATION_MINUTES=10

# Путь к директории с данными
DATA_DIR=./src/backend/data

# Путь к директории с логами
LOGS_DIR=./logs

# Секретный ключ для сессий
# ВАЖНО: Замените на надёжный случайный ключ в production!
# Генерация: openssl rand -base64 32
SESSION_SECRET=your-secret-key-change-this-in-production

# Настройки CORS (опционально)
# CORS_ORIGIN=http://localhost:3002
