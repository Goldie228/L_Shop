{
  "name": "l_shop",
  "version": "1.0.0",
  "description": "Прототип интернет-магазина на Express + TypeScript",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/app.js",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "nodemon src/backend/app.ts",
    "dev:frontend": "vite --config vite.config.ts",
    "build:frontend": "vite build --config vite.config.ts",
    "serve:frontend": "vite preview --config vite.config.ts",
    "lint": "eslint src/backend --ext ts",
    "lint:fix": "eslint src/backend --ext ts --fix",
    "lint:frontend": "eslint src/frontend --ext ts --config .eslintrc.frontend.js",
    "lint:frontend:fix": "eslint src/frontend --ext ts --config .eslintrc.frontend.js --fix",
    "format": "prettier --write src/backend",
    "format:frontend": "prettier --write src/frontend",
    "format:check": "prettier --check src/backend",
    "format:check:frontend": "prettier --check src/frontend",
    "test": "jest",
    "test:backend": "jest --config jest.config.js",
    "test:frontend": "jest --config jest.frontend.config.js",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:coverage:backend": "jest --config jest.config.js --coverage",
    "test:coverage:frontend": "jest --config jest.frontend.config.js --coverage",
    "test:verbose": "jest --verbose",
    "test:e2e": "cypress run",
    "test:e2e:open": "cypress open",
    "test:visual": "playwright test --config=playwright.visual.config.ts",
    "test:visual:components": "playwright test --config=playwright.visual.config.ts components.visual.spec.ts",
    "test:visual:pages": "playwright test --config=playwright.visual.config.ts pages.visual.spec.ts",
    "test:visual:update": "playwright test --config=playwright.visual.config.ts --update-snapshots",
    "test:visual:report": "playwright show-report src/frontend/__visual_tests__/report",
    "test:all": "npm run test:coverage && npm run test:e2e",
    "seed": "ts-node src/backend/scripts/seed.ts",
    "migrate": "ts-node src/backend/scripts/migrate-add-firstName.ts && ts-node src/backend/scripts/migrate-add-currency.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:backend": "tsc --noEmit --project src/backend",
    "typecheck:frontend": "tsc --noEmit --project src/frontend"
  },
  "keywords": [
    "express",
    "typescript",
    "ecommerce",
    "shop"
  ],
  "author": "Команда L_Shop",
  "license": "MIT",
  "dependencies": {
    "async-mutex": "^0.5.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.0",
    "helmet": "^8.1.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^1.0.0",
    "xss": "^1.0.15",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.3",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.2.5",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^5.59.8",
    "@typescript-eslint/parser": "^5.59.8",
    "concurrently": "^9.2.1",
    "cypress": "^15.10.0",
    "eslint": "^8.42.0",
    "eslint-config-airbnb-typescript": "^17.0.0",
    "eslint-plugin-import": "^2.27.5",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "nodemon": "^2.0.22",
    "prettier": "^2.8.8",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.3",
    "vite": "^4.5.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
